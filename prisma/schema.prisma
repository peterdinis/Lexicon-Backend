generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  password      String
  name          String?
  lastName      String?
  photoUrl      String?
  notifications Notification[]
  pages         Page[]           @relation("OwnerPages")
  events        CalendarEvent[]
  assignedTasks Task[]           @relation("UserAssignedTasks")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String
  pages     Page[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id             Int             @id @default(autoincrement())
  title          String
  isDatabase     Boolean         @default(false)
  parentPageId   Int?
  parentPage     Page?           @relation("SubPages", fields: [parentPageId], references: [id])
  subPages       Page[]          @relation("SubPages")
  workspaceId    Int
  workspace      Workspace       @relation(fields: [workspaceId], references: [id])
  contents       Content[]
  properties     Property[]
  emoji          String?      
  propertyValues PropertyValue[]
  publicUrl      String          @default("")
  events         CalendarEvent[]
  tasks          Task[]
  sortPosition   Int             @default(0)
  inTrash        Boolean?        @default(false)
  inPublished    Boolean?        @default(false)
  ownerId        Int
  owner          User            @relation("OwnerPages", fields: [ownerId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Task {
  id          Int         @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus  @default(todo)
  dueDate     DateTime?
  completedAt DateTime?
  pageId      Int
  page        Page        @relation(fields: [pageId], references: [id])
  assigneeId  Int?
  assignee    User?       @relation("UserAssignedTasks", fields: [assigneeId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum TaskStatus {
  todo
  in_progress
  done
  canceled
}

model Content {
  id        Int        @id @default(autoincrement())
  type      ContentType
  data      Json
  order     Int
  pageId    Int
  page      Page       @relation(fields: [pageId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum ContentType {
  paragraph
  heading
  todo
  code
  image
}

model Property {
  id        Int             @id @default(autoincrement())
  name      String
  type      PropertyType
  pageId    Int
  page      Page            @relation(fields: [pageId], references: [id])
  values    PropertyValue[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

enum PropertyType {
  text
  number
  checkbox
  date
  select
}

model PropertyValue {
  id         Int      @id @default(autoincrement())
  pageId     Int
  propertyId Int
  value      Json
  page       Page     @relation(fields: [pageId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CalendarEvent {
  id        Int      @id @default(autoincrement())
  title     String
  start     DateTime
  end       DateTime
  pageId    Int
  page      Page     @relation(fields: [pageId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  type        String   // e.g. "MESSAGE", "FRIEND_REQUEST", "SYSTEM"
  title       String
  description String?
  isRead      Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Template {
  id        String   @id @default(cuid())
  title     String
  blocks    Json     // Store blocks as JSON array
  createdBy String   // userId of creator
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdBy])
}